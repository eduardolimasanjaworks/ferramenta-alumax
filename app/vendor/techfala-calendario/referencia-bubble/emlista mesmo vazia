  const TARGET_ID = "1config-agenda"; // ID Attribute do botão no Bubble
  const TOOLTIP_TEXT = "Config.: nome da agenda";  // Texto do tooltip

  function initTooltip() {
    const el = document.getElementById(TARGET_ID);
    if (!el) {
      // tenta de novo se o elemento ainda não carregou
      setTimeout(initTooltip, 300);
      return;
